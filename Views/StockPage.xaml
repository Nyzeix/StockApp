<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:models="clr-namespace:StockApp.Models"
             xmlns:vm="clr-namespace:StockApp.ViewModels"
             x:Class="StockApp.Views.StockPage"
             x:Name="Stock"
             x:DataType="vm:StockViewModel"
             Title="📦 Stock">

    <Grid RowDefinitions="Auto, *" IgnoreSafeArea="False">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="15,10" Spacing="10" 
                             BackgroundColor="{AppThemeBinding Light={DynamicResource LightBlockBackgroundColor}, Dark={DynamicResource DarkBlockBackgroundColor}}">

            <SearchBar x:Name="ProductSearchBar"
                       Placeholder="Rechercher..."
                       Text="{Binding SearchText, Mode=TwoWay}"
                       BackgroundColor="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}"
                       TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"/>

            <!-- Filtres -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Border StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}" StrokeThickness="0">
                    <Picker x:Name="QuantityFilterPicker" Title="Qté" HorizontalTextAlignment="Center"
                            ItemsSource="{Binding AvailableQuantities}"
                            SelectedItem="{Binding SelectedQuantity}"/>
                </Border>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}" StrokeThickness="0">
                    <Picker x:Name="OriginFilterPicker" Title="Origine" HorizontalTextAlignment="Center"
                            ItemsSource="{Binding AvailableOrigins}"
                            SelectedItem="{Binding SelectedOrigin}"/>
                </Border>
                <Border Grid.Column="2" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}" StrokeThickness="0">
                    <Picker x:Name="SupplierFilterPicker" Title="Frn." HorizontalTextAlignment="Center"
                            ItemsSource="{Binding AvailableSuppliers}"
                            SelectedItem="{Binding SelectedSupplier}"/>
                </Border>
            </Grid>
        </VerticalStackLayout>

        <!-- Liste des produits -->
        <CollectionView Grid.Row="1"
                        x:Name="StockCollectionView"
                        ItemsSource="{Binding StockItems}"
                        SelectionMode="None"
                        RemainingItemsThreshold="5"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>

            <CollectionView.Header>
                <BoxView HeightRequest="10" Color="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}"/>
            </CollectionView.Header>
            <CollectionView.Footer>
                <!-- Espace pour le Floating Button -->
                <BoxView HeightRequest="80" Color="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}"/>
            </CollectionView.Footer>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Product">
                    <Grid Padding="15,0">
                        <Border StrokeShape="RoundRectangle 15"
                                BackgroundColor="{AppThemeBinding Light={DynamicResource LightBlockBackgroundColor}, Dark={DynamicResource DarkBlockBackgroundColor}}"
                                StrokeThickness="0"
                                Padding="15">

                            <!-- Gestion de l'appui long -->
                            <Border.Behaviors>
                                <toolkit:TouchBehavior 
                                    Command="{Binding Source={x:Reference Stock}, Path=SimplePressEditCommand}"
                                    CommandParameter="{Binding .}"
                                    LongPressDuration="800"
                                    LongPressCommand="{Binding Source={x:Reference Stock}, Path=BindingContext.LongPressDeleteCommand}"
                                    LongPressCommandParameter="{Binding .}"
                                    DefaultAnimationDuration="100"
                                    DefaultOpacity="1"
                                    PressedOpacity="0.8" />
                            </Border.Behaviors>

                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1"/>
                            </Border.Shadow>

                            <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                                <!-- Nom -->
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"/>

                                <!-- Badge Quantité -->
                                <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1565C0}" StrokeShape="RoundRectangle 8" Padding="8,4">
                                    <Label Text="{Binding Quantity, StringFormat='{0} ex.'}" TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}" FontSize="12" FontAttributes="Bold"/>
                                </Border>

                                <!-- Détails -->
                                <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="10" Margin="0,5">
                                    <Label Text="{Binding Origin, StringFormat='🌍 {0}'}" FontSize="13" TextColor="#777"/>
                                    <Label Text="{Binding Supplier, StringFormat='🏢 {0}'}" FontSize="13" TextColor="#777"/>
                                </HorizontalStackLayout>

                                <!-- Footer -->
                                <Label Grid.Row="2" Grid.ColumnSpan="2" 
                                       Text="{Binding ExpirationDate, StringFormat='Péremption : {0:dd/MM/yyyy}'}" 
                                       TextColor="#D32F2F" FontSize="12" Margin="0,5,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Floating Button Action -->
        <Button Grid.Row="1"
                Text="+"
                FontSize="32"
                TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"
                BackgroundColor="{AppThemeBinding Light={DynamicResource LightPrimaryButtonColor}, Dark={DynamicResource DarkPrimaryButtonColor}}"
                CornerRadius="30"
                HeightRequest="60"
                WidthRequest="60"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                Clicked="OnAddButtonClicked">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="6" Opacity="0.3"/>
            </Button.Shadow>
        </Button>

    </Grid>
</ContentPage>

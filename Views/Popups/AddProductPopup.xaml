<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="StockApp.Views.Popups.AddProductPopup"
               Color="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Border x:Name="PopupContainer"
            StrokeShape="RoundRectangle 20" 
            BackgroundColor="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}"
            Padding="20"
            HorizontalOptions="Center">

        <VerticalStackLayout Spacing="15">
            <Label Text="Nouveau Produit" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"/>

            <Entry x:Name="NameEntry" Placeholder="Nom du produit" />

            <Grid ColumnDefinitions="*,*">
                <Entry Grid.Column="0" x:Name="QuantityEntry" Placeholder="Quantité" Keyboard="Numeric"/>
                <Entry Grid.Column="1" x:Name="ColorEntry" Placeholder="Couleur" Margin="10,0,0,0"/>
            </Grid>

            <Grid ColumnDefinitions="*,*">
                <Entry Grid.Column="0" x:Name="OriginEntry" Placeholder="Origine" />
            </Grid>
            <Grid ColumnDefinitions="*,*">
                <Picker x:Name="SupplierPicker" Title="Fournisseur"/>
            </Grid>

            <DatePicker x:Name="ExpirationDatePicker" Format="dd/MM/yyyy" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                <Button Text="Annuler"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource LightSecondaryButtonColor}, Dark={DynamicResource DarkSecondaryButtonColor}}"
                        TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"
                        Clicked="OnCancelClicked"
                        Grid.Column="0"/>

                <Button Text="Valider"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource LightPrimaryButtonColor}, Dark={DynamicResource DarkPrimaryButtonColor}}"
                        TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"
                        Clicked="OnSaveClicked"
                        Grid.Column="1"/>
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
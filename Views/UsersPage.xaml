<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:models="clr-namespace:StockApp.Models"
             xmlns:vm="clr-namespace:StockApp.ViewModels"
             x:Class="StockApp.Views.UsersPage"
             x:Name="Users"
             x:DataType="vm:UserViewModel"
             Title="Gestion des utilisateurs">
    
    <Grid RowDefinitions="Auto, *" IgnoreSafeArea="False">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="15,10" Spacing="10" 
                             BackgroundColor="{AppThemeBinding Light={DynamicResource LightBlockBackgroundColor}, Dark={DynamicResource DarkBlockBackgroundColor}}">

            <SearchBar x:Name="UserSearchBar"
                       Placeholder="Rechercher..."
                       Text="{Binding SearchText, Mode=TwoWay}"
                       BackgroundColor="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}"
                       TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"/>
        </VerticalStackLayout>

        <!-- Liste des utilisateurs -->
        <CollectionView Grid.Row="1"
                        x:Name="UserCollectionView"
                        ItemsSource="{Binding Users}"
                        SelectionMode="None"
                        RemainingItemsThreshold="5"
                        BackgroundColor="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>

            <CollectionView.Header>
                <BoxView HeightRequest="10" Color="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}"/>
            </CollectionView.Header>
            <CollectionView.Footer>
                <!-- Espace pour le Floating Button -->
                <BoxView HeightRequest="80" Color="{AppThemeBinding Light={DynamicResource LightBackgroundColor}, Dark={DynamicResource DarkBackgroundColor}}"/>
            </CollectionView.Footer>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:User">
                    <Grid Padding="15,0">
                        <Border StrokeShape="RoundRectangle 15"
                                BackgroundColor="{AppThemeBinding Light={DynamicResource LightBlockBackgroundColor}, Dark={DynamicResource DarkBlockBackgroundColor}}"
                                StrokeThickness="0"
                                Padding="15">

                            <!-- Gestion de l'appui long -->
                            <Border.Behaviors>
                                <toolkit:TouchBehavior 
                                    Command="{Binding Source={x:Reference Users}, Path=SimplePressEditCommand}"
                                    CommandParameter="{Binding .}"
                                    LongPressDuration="800"
                                    LongPressCommand="{Binding Source={x:Reference Users}, Path=BindingContext.LongPressDeleteCommand}"
                                    LongPressCommandParameter="{Binding .}"
                                    DefaultAnimationDuration="100"
                                    DefaultOpacity="1"
                                    PressedOpacity="0.8" />
                            </Border.Behaviors>

                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1"/>
                            </Border.Shadow>

                            <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                                <!-- Nom -->
                                <Label Text="{Binding Username}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"/>
                                <!-- Status -->
                                <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="10" Margin="0,5">
                                    <Label Text="{Binding IsAdmin, Converter={StaticResource BooleanToTextConverter}, ConverterParameter='Admin;Standard'}"
                                        FontSize="13"
                                        TextColor="#777"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Floating Button Action -->
        <Button Grid.Row="1"
                Text="+"
                FontSize="32"
                TextColor="{AppThemeBinding Light={DynamicResource LightTextColor}, Dark={DynamicResource DarkTextColor}}"
                BackgroundColor="{AppThemeBinding Light={DynamicResource LightPrimaryButtonColor}, Dark={DynamicResource DarkPrimaryButtonColor}}"
                CornerRadius="30"
                HeightRequest="60"
                WidthRequest="60"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                Clicked="OnAddButtonClicked">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="6" Opacity="0.3"/>
            </Button.Shadow>
        </Button>
    </Grid>
</ContentPage>